        "policy_profile": {
          "type": "string"
        },
        "policy_file": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_file": {
          "$ref": "#/$defs/nullableString"
        },
        "counts_by_priority": {
          "$ref": "#/$defs/integerMap"
        },
        "source_stats": {
          "$ref": "#/$defs/integerMap"
        },
        "data_sources": {
          "$ref": "#/$defs/stringArray"
        },
        "cache_enabled": {
          "type": "boolean"
        },
        "cache_dir": {
          "$ref": "#/$defs/nullableString"
        },
        "epss_diagnostics": {
          "$ref": "#/$defs/providerLookupDiagnostics"
        },
        "kev_diagnostics": {
          "$ref": "#/$defs/providerLookupDiagnostics"
        },
        "provider_degraded": {
          "type": "boolean"
        },
        "provider_diagnostics": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/providerLookupDiagnostics"
          }
