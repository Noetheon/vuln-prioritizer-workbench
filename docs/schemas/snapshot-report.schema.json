        },
        "mapping_framework_version": {
          "$ref": "#/$defs/nullableString"
        },
        "warnings": {
          "$ref": "#/$defs/stringArray"
        },
        "total_input": {
          "type": "integer"
        },
        "valid_input": {
          "type": "integer"
        },
        "occurrences_count": {
          "type": "integer"
        },
        "findings_count": {
          "type": "integer"
        },
        "filtered_out_count": {
          "type": "integer"
        },
        "nvd_hits": {
          "type": "integer"
        },
        "nvd_diagnostics": {
          "$ref": "#/$defs/providerLookupDiagnostics"
        },
        "epss_hits": {
          "type": "integer"
        },
        "kev_hits": {
          "type": "integer"
        },
        "attack_hits": {
          "type": "integer"
        },
        "suppressed_by_vex": {
          "type": "integer"
        },
        "under_investigation_count": {
          "type": "integer"
        },
        "asset_match_conflict_count": {
          "type": "integer"
        },
        "vex_conflict_count": {
          "type": "integer"
        },
        "waived_count": {
          "type": "integer"
        },
        "waiver_review_due_count": {
          "type": "integer"
        },
        "expired_waiver_count": {
          "type": "integer"
        },
        "active_filters": {
          "$ref": "#/$defs/stringArray"
        },
        "policy_overrides": {
          "$ref": "#/$defs/stringArray"
        },
        "priority_policy": {
          "$ref": "#/$defs/priorityPolicy"
