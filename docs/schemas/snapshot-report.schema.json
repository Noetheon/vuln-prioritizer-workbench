{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noetheon.github.io/vuln-prioritizer/schemas/snapshot-report.schema.json",
  "title": "vuln-prioritizer snapshot report",
  "description": "JSON contract for `snapshot create --format json`.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "metadata",
    "attack_summary",
    "findings"
  ],
  "properties": {
    "metadata": {
      "$ref": "#/$defs/snapshotMetadata"
    },
    "attack_summary": {
      "$ref": "#/$defs/attackSummary"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prioritizedFinding"
      }
    }
  },
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullableNumber": {
      "type": [
        "number",
        "null"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "integerMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "inputSourceSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "input_path",
        "input_format",
        "total_rows",
        "occurrence_count",
        "unique_cves",
        "warning_count"
      ],
      "properties": {
        "input_path": {
          "type": "string"
        },
        "input_format": {
          "type": "string"
        },
        "total_rows": {
          "type": "integer"
        },
        "occurrence_count": {
          "type": "integer"
        },
        "unique_cves": {
          "type": "integer"
        },
        "warning_count": {
          "type": "integer"
        },
        "included_occurrence_count": {
          "type": [
            "integer",
            "null"
          ]
        },
        "included_unique_cves": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "providerLookupDiagnostics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requested": {
          "type": "integer"
        },
        "cache_hits": {
          "type": "integer"
        },
        "network_fetches": {
          "type": "integer"
        },
        "failures": {
          "type": "integer"
        },
        "content_hits": {
          "type": "integer"
        },
        "empty_records": {
          "type": "integer"
        },
        "stale_cache_hits": {
          "type": "integer"
        },
        "degraded": {
          "type": "boolean"
        }
      }
    },
    "priorityPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "critical_epss_threshold": {
          "type": "number"
        },
        "critical_cvss_threshold": {
          "type": "number"
        },
        "high_epss_threshold": {
          "type": "number"
        },
        "high_cvss_threshold": {
          "type": "number"
        },
        "medium_epss_threshold": {
          "type": "number"
        },
        "medium_cvss_threshold": {
          "type": "number"
        }
      }
    },
    "attackSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mapped_cves",
        "unmapped_cves",
        "mapping_type_distribution",
        "technique_distribution",
        "tactic_distribution"
      ],
      "properties": {
        "mapped_cves": {
          "type": "integer"
        },
        "unmapped_cves": {
          "type": "integer"
        },
        "mapping_type_distribution": {
          "$ref": "#/$defs/integerMap"
        },
        "technique_distribution": {
          "$ref": "#/$defs/integerMap"
        },
        "tactic_distribution": {
          "$ref": "#/$defs/integerMap"
        }
      }
    },
    "analysisMetadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "input_path",
        "output_format",
        "generated_at"
