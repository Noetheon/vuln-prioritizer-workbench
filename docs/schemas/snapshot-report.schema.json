        "provider_snapshot_id": {
          "$ref": "#/$defs/nullableString"
        },
        "provider_snapshot_hash": {
          "$ref": "#/$defs/nullableString"
        },
        "locked_provider_data": {
          "type": "boolean"
        },
        "provider_snapshot_sources": {
          "$ref": "#/$defs/stringArray"
        },
        "defensive_context_file": {
          "description": "Optional local JSON overlay file used for OSV, GHSA, Vulnrichment, or SSVC defensive context. This field is contextual evidence only and does not affect base priority scoring.",
          "$ref": "#/$defs/nullableString"
        },
        "defensive_context_sources": {
          "description": "Sorted local defensive context source names present in the run, for example osv, ghsa, vulnrichment, or ssvc.",
          "$ref": "#/$defs/stringArray"
        },
        "defensive_context_hits": {
          "description": "Number of findings with at least one local defensive context overlay. This count is informational and does not change priority_label.",
          "type": "integer"
        },
        "attack_enabled": {
          "type": "boolean"
        },
        "attack_source": {
          "type": "string"
        },
        "attack_mapping_file": {
          "$ref": "#/$defs/nullableString"
