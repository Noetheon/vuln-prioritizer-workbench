      "properties": {
        "schema_version": {
          "const": "1.1.0"
        },
        "input_path": {
          "type": "string"
        },
        "output_path": {
          "$ref": "#/$defs/nullableString"
        },
        "config_file": {
          "$ref": "#/$defs/nullableString"
        },
        "output_format": {
          "const": "json"
        },
        "generated_at": {
          "type": "string"
        },
        "input_format": {
          "type": "string"
        },
        "input_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inputSourceSummary"
          }
