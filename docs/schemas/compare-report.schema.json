{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noetheon.github.io/vuln-prioritizer/schemas/compare-report.schema.json",
  "title": "vuln-prioritizer compare report",
  "description": "JSON contract for `vuln-prioritizer compare --format json`.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "metadata",
    "attack_summary",
    "comparisons"
  ],
  "properties": {
    "metadata": {
      "$ref": "#/$defs/analysisMetadata"
    },
    "attack_summary": {
      "$ref": "#/$defs/attackSummary"
    },
    "comparisons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/comparisonFinding"
      }
    }
  },
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullableNumber": {
      "type": [
        "number",
        "null"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "integerMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "inputSourceSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "input_path",
        "input_format",
        "total_rows",
        "occurrence_count",
        "unique_cves",
        "warning_count"
      ],
      "properties": {
        "input_path": {
          "type": "string"
        },
        "input_format": {
          "type": "string"
        },
        "total_rows": {
          "type": "integer"
        },
        "occurrence_count": {
          "type": "integer"
        },
        "unique_cves": {
          "type": "integer"
        },
        "warning_count": {
          "type": "integer"
        },
        "included_occurrence_count": {
          "type": [
            "integer",
            "null"
          ]
        },
        "included_unique_cves": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "providerLookupDiagnostics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requested": {
          "type": "integer"
        },
        "cache_hits": {
          "type": "integer"
        },
        "network_fetches": {
          "type": "integer"
        },
        "failures": {
          "type": "integer"
        },
        "content_hits": {
          "type": "integer"
        },
        "empty_records": {
          "type": "integer"
        },
        "stale_cache_hits": {
          "type": "integer"
        },
        "degraded": {
          "type": "boolean"
        }
      }
    },
    "providerDataQualityFlag": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source",
        "code",
        "message"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "code": {
          "description": "Canonical provider quality code. VPW-027 adds nvd_missing, nvd_cvss_missing, epss_missing, epss_outdated, kev_unavailable, snapshot_locked, and provider_error; legacy generic provider codes remain additive.",
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "cve_id": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "priorityPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "critical_epss_threshold": {
          "type": "number"
        },
        "critical_cvss_threshold": {
          "type": "number"
        },
        "high_epss_threshold": {
          "type": "number"
        },
        "high_cvss_threshold": {
          "type": "number"
        },
        "medium_epss_threshold": {
          "type": "number"
        },
        "medium_cvss_threshold": {
          "type": "number"
        }
      }
    },
    "attackSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mapped_cves",
        "unmapped_cves",
        "mapping_type_distribution",
        "technique_distribution",
        "tactic_distribution"
      ],
      "properties": {
        "mapped_cves": {
          "type": "integer"
        },
        "unmapped_cves": {
          "type": "integer"
        },
        "mapping_type_distribution": {
          "$ref": "#/$defs/integerMap"
        },
        "technique_distribution": {
          "$ref": "#/$defs/integerMap"
        },
        "tactic_distribution": {
          "$ref": "#/$defs/integerMap"
        }
      }
    },
    "analysisMetadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "input_path",
        "output_format",
        "generated_at"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0.0"
        },
        "input_path": {
          "type": "string"
        },
        "output_path": {
          "$ref": "#/$defs/nullableString"
        },
        "config_file": {
          "$ref": "#/$defs/nullableString"
        },
        "output_format": {
          "const": "json"
        },
        "generated_at": {
          "type": "string"
        },
        "input_format": {
          "type": "string"
        },
        "input_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inputSourceSummary"
          }
        },
        "merged_input_count": {
          "type": "integer"
        },
        "duplicate_cve_count": {
          "type": "integer"
        },
        "provider_snapshot_file": {
          "$ref": "#/$defs/nullableString"
        },
        "provider_snapshot_id": {
          "$ref": "#/$defs/nullableString"
        },
        "provider_snapshot_hash": {
          "$ref": "#/$defs/nullableString"
        },
        "locked_provider_data": {
          "type": "boolean"
        },
        "provider_snapshot_sources": {
          "$ref": "#/$defs/stringArray"
        },
        "attack_enabled": {
          "type": "boolean"
        },
        "attack_source": {
          "type": "string"
        },
        "attack_mapping_file": {
          "$ref": "#/$defs/nullableString"
        },
        "attack_technique_metadata_file": {
          "$ref": "#/$defs/nullableString"
        },
        "attack_source_version": {
          "$ref": "#/$defs/nullableString"
        },
        "attack_version": {
          "$ref": "#/$defs/nullableString"
        },
        "attack_domain": {
          "$ref": "#/$defs/nullableString"
        },
        "mapping_framework": {
          "$ref": "#/$defs/nullableString"
        },
        "mapping_framework_version": {
          "$ref": "#/$defs/nullableString"
        },
        "warnings": {
          "$ref": "#/$defs/stringArray"
        },
        "total_input": {
          "type": "integer"
        },
        "valid_input": {
          "type": "integer"
        },
        "occurrences_count": {
          "type": "integer"
        },
        "findings_count": {
          "type": "integer"
        },
        "filtered_out_count": {
          "type": "integer"
        },
        "nvd_hits": {
          "type": "integer"
        },
        "nvd_diagnostics": {
          "$ref": "#/$defs/providerLookupDiagnostics"
        },
        "epss_hits": {
          "type": "integer"
        },
        "kev_hits": {
          "type": "integer"
        },
        "attack_hits": {
          "type": "integer"
        },
        "suppressed_by_vex": {
          "type": "integer"
        },
        "under_investigation_count": {
          "type": "integer"
        },
        "asset_match_conflict_count": {
          "type": "integer"
        },
        "vex_conflict_count": {
          "type": "integer"
        },
        "waived_count": {
          "type": "integer"
        },
        "waiver_review_due_count": {
          "type": "integer"
        },
        "expired_waiver_count": {
          "type": "integer"
        },
        "active_filters": {
          "$ref": "#/$defs/stringArray"
        },
        "policy_overrides": {
          "$ref": "#/$defs/stringArray"
        },
        "priority_policy": {
          "$ref": "#/$defs/priorityPolicy"
        },
        "policy_profile": {
          "type": "string"
        },
        "policy_file": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_file": {
          "$ref": "#/$defs/nullableString"
        },
        "counts_by_priority": {
          "$ref": "#/$defs/integerMap"
        },
        "source_stats": {
          "$ref": "#/$defs/integerMap"
        },
        "data_sources": {
          "$ref": "#/$defs/stringArray"
        },
        "cache_enabled": {
          "type": "boolean"
        },
        "cache_dir": {
          "$ref": "#/$defs/nullableString"
        },
        "epss_diagnostics": {
          "$ref": "#/$defs/providerLookupDiagnostics"
        },
        "kev_diagnostics": {
          "$ref": "#/$defs/providerLookupDiagnostics"
        },
        "provider_degraded": {
          "type": "boolean"
        },
        "provider_diagnostics": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/providerLookupDiagnostics"
          }
        },
        "provider_data_quality_flags": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/providerDataQualityFlag"
            }
          }
        },
        "provider_freshness": {
          "type": "object",
          "properties": {
            "nvd_freshness_at": {
              "$ref": "#/$defs/nullableString"
            },
            "epss_freshness_at": {
              "$ref": "#/$defs/nullableString"
            },
            "kev_freshness_at": {
              "$ref": "#/$defs/nullableString"
            },
            "provider_snapshot_generated_at": {
              "$ref": "#/$defs/nullableString"
            },
            "lookup_completed_at": {
              "$ref": "#/$defs/nullableString"
            }
          },
          "additionalProperties": {
            "type": [
              "string",
              "integer",
              "number",
              "boolean",
              "null"
            ]
          }
        },
        "included_occurrence_count": {
          "type": "integer"
        },
        "included_unique_cves": {
          "type": "integer"
        }
      }
    },
    "inputOccurrence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "cve_id"
      ],
      "properties": {
        "cve_id": {
          "type": "string"
        },
        "source_format": {
          "type": "string"
        },
        "component_name": {
          "$ref": "#/$defs/nullableString"
        },
        "component_version": {
          "$ref": "#/$defs/nullableString"
        },
        "purl": {
          "$ref": "#/$defs/nullableString"
        },
        "package_type": {
          "$ref": "#/$defs/nullableString"
        },
        "file_path": {
          "$ref": "#/$defs/nullableString"
        },
        "dependency_path": {
          "$ref": "#/$defs/nullableString"
        },
        "fix_versions": {
          "$ref": "#/$defs/stringArray"
        },
        "source_record_id": {
          "$ref": "#/$defs/nullableString"
        },
        "raw_severity": {
          "$ref": "#/$defs/nullableString"
        },
        "target_kind": {
          "type": "string"
        },
        "target_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_id": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_criticality": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_exposure": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_environment": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_owner": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_business_service": {
          "$ref": "#/$defs/nullableString"
        },
        "vex_status": {
          "$ref": "#/$defs/nullableString"
        },
        "vex_justification": {
          "$ref": "#/$defs/nullableString"
        },
        "vex_action_statement": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_match_rule_id": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_match_row": {
          "type": [
            "integer",
            "null"
          ]
        },
        "asset_match_mode": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_match_pattern": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_match_precedence": {
          "type": [
            "integer",
            "null"
          ]
        },
        "asset_match_candidate_count": {
          "type": "integer"
        },
        "vex_match_type": {
          "$ref": "#/$defs/nullableString"
        },
        "vex_source_format": {
          "$ref": "#/$defs/nullableString"
        },
        "vex_source_record_id": {
          "$ref": "#/$defs/nullableString"
        },
        "vex_source_path": {
          "$ref": "#/$defs/nullableString"
        },
        "vex_candidate_count": {
          "type": "integer"
        }
      }
    },
    "findingProvenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "occurrence_count": {
          "type": "integer"
        },
        "active_occurrence_count": {
          "type": "integer"
        },
        "suppressed_occurrence_count": {
          "type": "integer"
        },
        "source_formats": {
          "$ref": "#/$defs/stringArray"
        },
        "components": {
          "$ref": "#/$defs/stringArray"
        },
        "affected_paths": {
          "$ref": "#/$defs/stringArray"
        },
        "fix_versions": {
          "$ref": "#/$defs/stringArray"
        },
        "targets": {
          "$ref": "#/$defs/stringArray"
        },
        "asset_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "highest_asset_criticality": {
          "$ref": "#/$defs/nullableString"
        },
        "highest_asset_exposure": {
          "$ref": "#/$defs/nullableString"
        },
        "asset_count": {
          "type": "integer"
        },
        "vex_statuses": {
          "$ref": "#/$defs/integerMap"
        },
        "occurrences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inputOccurrence"
          }
        }
      }
    },
    "comparisonFinding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "cve_id",
        "cvss_only_label",
        "cvss_only_rank",
        "enriched_label",
        "enriched_rank",
        "changed",
        "delta_rank",
        "change_reason"
      ],
      "properties": {
        "cve_id": {
          "type": "string"
        },
        "description": {
          "$ref": "#/$defs/nullableString"
        },
        "cvss_base_score": {
          "$ref": "#/$defs/nullableNumber"
        },
        "cvss_severity": {
          "$ref": "#/$defs/nullableString"
        },
        "cvss_version": {
          "$ref": "#/$defs/nullableString"
        },
        "epss": {
          "$ref": "#/$defs/nullableNumber"
        },
        "epss_percentile": {
          "$ref": "#/$defs/nullableNumber"
        },
        "in_kev": {
          "type": "boolean"
        },
        "cvss_only_label": {
          "type": "string"
        },
        "cvss_only_rank": {
          "type": "integer"
        },
        "enriched_label": {
          "type": "string"
        },
        "enriched_rank": {
          "type": "integer"
        },
        "attack_mapped": {
          "type": "boolean"
        },
        "attack_relevance": {
          "type": "string"
        },
        "mapped_technique_count": {
          "type": "integer"
        },
        "mapped_tactics": {
          "$ref": "#/$defs/stringArray"
        },
        "data_quality_flags": {
          "description": "Finding-scoped provider data-quality flags that explain missing, stale, locked, or degraded enrichment signals used for this comparison row.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/providerDataQualityFlag"
          }
        },
        "data_quality_confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/findingProvenance"
        },
        "context_summary": {
          "$ref": "#/$defs/nullableString"
        },
        "suppressed_by_vex": {
          "type": "boolean"
        },
        "under_investigation": {
          "type": "boolean"
        },
        "waived": {
          "type": "boolean"
        },
        "waiver_status": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_reason": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_owner": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_expires_on": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_review_on": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_days_remaining": {
          "type": [
            "integer",
            "null"
          ]
        },
        "changed": {
          "type": "boolean"
        },
        "delta_rank": {
          "type": "integer"
        },
        "change_reason": {
          "type": "string"
        },
        "waiver_id": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_matched_scope": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_approval_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "waiver_ticket_url": {
          "$ref": "#/$defs/nullableString"
        },
        "operational_rank": {
          "type": "integer"
        },
        "context_rank_reasons": {
          "$ref": "#/$defs/stringArray"
        },
        "waiver_scope": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "remediationComponent": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "$ref": "#/$defs/nullableString"
        },
        "current_version": {
          "$ref": "#/$defs/nullableString"
        },
        "fixed_versions": {
          "$ref": "#/$defs/stringArray"
        },
        "package_type": {
          "$ref": "#/$defs/nullableString"
        },
        "purl": {
          "$ref": "#/$defs/nullableString"
        },
        "path": {
          "$ref": "#/$defs/nullableString"
        },
        "occurrence_count": {
          "type": "integer"
        },
        "targets": {
          "$ref": "#/$defs/stringArray"
        },
        "asset_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "services": {
          "$ref": "#/$defs/stringArray"
        },
        "owners": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "remediationPlan": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "strategy": {
          "type": "string"
        },
        "ecosystem": {
          "$ref": "#/$defs/nullableString"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/remediationComponent"
          }
        },
        "evidence_level": {
          "type": "string"
        },
        "kev_required_action": {
          "$ref": "#/$defs/nullableString"
        },
        "kev_due_date": {
          "$ref": "#/$defs/nullableString"
        },
        "suppressed_occurrence_count": {
          "type": "integer"
        }
      }
    }
  }
}
