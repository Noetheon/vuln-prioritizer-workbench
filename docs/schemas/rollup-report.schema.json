{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noetheon.github.io/vuln-prioritizer/schemas/rollup-report.schema.json",
  "title": "vuln-prioritizer rollup report",
  "description": "JSON contract for `rollup --format json`.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "buckets"
  ],
  "properties": {
    "metadata": {
      "$ref": "#/$defs/rollupMetadata"
    },
    "buckets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rollupBucket"
      }
    }
  },
  "$defs": {
    "rollupMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "generated_at",
        "input_path",
        "input_kind",
        "dimension",
        "bucket_count",
        "top"
      ],
      "properties": {
        "schema_version": {
          "const": "1.2.0"
        },
        "generated_at": {
          "type": "string"
        },
        "input_path": {
          "type": "string"
        },
        "input_kind": {
          "type": "string"
        },
        "dimension": {
          "type": "string"
        },
        "bucket_count": {
          "type": "integer"
        },
        "top": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "rollupBucket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bucket",
        "dimension",
        "remediation_rank",
        "finding_count",
        "actionable_count",
        "critical_count",
        "high_count",
        "kev_count",
        "attack_mapped_count",
        "waived_count",
        "waiver_review_due_count",
        "expired_waiver_count",
        "internet_facing_count",
        "production_count",
        "highest_priority",
        "rank_reason",
        "context_hints",
        "owners",
        "top_cves",
        "recommended_actions",
        "top_candidates"
      ],
      "properties": {
        "bucket": {
          "type": "string"
        },
        "dimension": {
          "type": "string"
        },
        "remediation_rank": {
          "type": "integer",
          "minimum": 1
        },
        "finding_count": {
          "type": "integer"
        },
        "actionable_count": {
          "type": "integer"
        },
        "critical_count": {
          "type": "integer"
        },
        "high_count": {
          "type": "integer"
        },
        "kev_count": {
          "type": "integer"
        },
        "attack_mapped_count": {
          "type": "integer"
        },
        "waived_count": {
          "type": "integer"
        },
        "waiver_review_due_count": {
          "type": "integer"
        },
        "expired_waiver_count": {
          "type": "integer"
        },
        "internet_facing_count": {
          "type": "integer"
        },
        "production_count": {
          "type": "integer"
        },
        "highest_priority": {
          "type": "string"
        },
        "rank_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "context_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "top_cves": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "top_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rollupCandidate"
          }
        }
      }
    },
    "rollupCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cve_id",
        "priority_label",
        "waived",
        "waiver_status",
        "in_kev",
        "highest_asset_criticality",
        "highest_asset_exposure",
        "asset_ids",
        "services",
        "owners",
        "recommended_action",
        "rank_reason"
      ],
      "properties": {
        "cve_id": {
          "type": "string"
        },
        "priority_label": {
          "type": "string"
        },
        "waived": {
          "type": "boolean"
        },
        "waiver_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "in_kev": {
          "type": "boolean"
        },
        "highest_asset_criticality": {
          "type": [
            "string",
            "null"
          ]
        },
        "highest_asset_exposure": {
          "type": [
            "string",
            "null"
          ]
        },
        "asset_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_action": {
          "type": "string"
        },
        "rank_reason": {
          "type": "string"
        },
        "remediation": {
          "$ref": "#/$defs/remediationPlan"
        }
      }
    },
    "remediationComponent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "fixed_versions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "package_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "purl": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "remediationPlan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string"
        },
        "ecosystem": {
          "type": [
            "string",
            "null"
          ]
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/remediationComponent"
          }
        }
      }
    }
  }
}
