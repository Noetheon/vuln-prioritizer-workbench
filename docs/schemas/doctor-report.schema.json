{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noetheon.github.io/vuln-prioritizer/schemas/doctor-report.schema.json",
  "title": "vuln-prioritizer doctor report",
  "description": "JSON contract for `vuln-prioritizer doctor --format json`.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "generated_at", "live", "summary", "checks"],
  "properties": {
    "schema_version": {
      "const": "1.2.0"
    },
    "generated_at": {
      "type": "string"
    },
    "live": {
      "type": "boolean"
    },
    "config_file": {
      "$ref": "#/$defs/nullableString"
    },
    "summary": {
      "$ref": "#/$defs/doctorSummary"
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/doctorCheck"
      }
    }
  },
  "$defs": {
    "nullableString": {
      "type": ["string", "null"]
    },
    "doctorSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["overall_status", "ok_count", "degraded_count", "error_count"],
      "properties": {
        "overall_status": {
          "enum": ["ok", "degraded", "error"]
        },
        "ok_count": {
          "type": "integer"
        },
        "degraded_count": {
          "type": "integer"
        },
        "error_count": {
          "type": "integer"
        }
      }
    },
    "doctorCheck": {
      "type": "object",
      "additionalProperties": true,
      "required": ["check_id", "name", "scope", "category", "status", "detail"],
      "properties": {
        "check_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "scope": {
          "enum": ["local", "live"]
        },
        "category": {
          "type": "string"
        },
        "status": {
          "enum": ["ok", "degraded", "error"]
        },
        "detail": {
          "type": "string"
        },
        "hint": {
          "$ref": "#/$defs/nullableString"
        }
      }
    }
  }
}
