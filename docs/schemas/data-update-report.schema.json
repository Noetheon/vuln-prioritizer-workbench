{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noetheon.github.io/vuln-prioritizer/schemas/data-update-report.schema.json",
  "title": "vuln-prioritizer data update report",
  "description": "JSON contract for `vuln-prioritizer data update --format json`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "summary", "requested_cve_ids", "sources", "warnings"],
  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "requested_cve_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/updateSource"
      }
    },
    "warnings": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "nullableInteger": {
      "type": ["integer", "null"]
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "command",
        "generated_at",
        "output_format",
        "output_path",
        "cache_dir",
        "cache_ttl_hours",
        "input_path",
        "input_paths",
        "merged_input_count",
        "input_format",
        "max_cves",
        "offline_kev_file",
        "nvd_api_key_env"
      ],
      "properties": {
        "schema_version": {
          "const": "1.2.0"
        },
        "command": {
          "const": "data update"
        },
        "generated_at": {
          "type": "string"
        },
        "output_format": {
          "const": "json"
        },
        "output_path": {
          "$ref": "#/$defs/nullableString"
        },
        "cache_dir": {
          "type": "string"
        },
        "cache_ttl_hours": {
          "type": "integer",
          "minimum": 1
        },
        "input_path": {
          "$ref": "#/$defs/nullableString"
        },
        "input_paths": {
          "$ref": "#/$defs/stringArray"
        },
        "merged_input_count": {
          "type": "integer",
          "minimum": 0
        },
        "input_format": {
          "type": "string"
        },
        "max_cves": {
          "$ref": "#/$defs/nullableInteger"
        },
        "offline_kev_file": {
          "$ref": "#/$defs/nullableString"
        },
        "nvd_api_key_env": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_sources", "requested_cves", "updated_sources"],
      "properties": {
        "selected_sources": {
          "$ref": "#/$defs/stringArray"
        },
        "requested_cves": {
          "type": "integer",
          "minimum": 0
        },
        "updated_sources": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "updateSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "mode",
        "requested_cves",
        "cached_records",
        "latest_cached_at",
        "details"
      ],
      "properties": {
        "source": {
          "enum": ["nvd", "epss", "kev"]
        },
        "mode": {
          "enum": ["live/api", "live/catalog", "offline file"]
        },
        "requested_cves": {
          "type": "integer",
          "minimum": 0
        },
        "cached_records": {
          "type": "integer",
          "minimum": 0
        },
        "latest_cached_at": {
          "$ref": "#/$defs/nullableString"
        },
        "details": {
          "type": "string"
        }
      }
    }
  }
}
