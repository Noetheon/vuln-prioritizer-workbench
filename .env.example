# Template identity and local routing
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local
PROJECT_NAME=Vuln Prioritizer Workbench
STACK_NAME=vuln-prioritizer-workbench
VITE_API_URL=http://localhost:8000

# Template backend placeholders. Replace these before any shared deployment.
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173

# Email placeholders kept for template parity.
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=true
SMTP_SSL=false
SMTP_PORT=587

# Local Compose database defaults.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=workbench
POSTGRES_USER=workbench
POSTGRES_PASSWORD=workbench

# Container images.
DOCKER_IMAGE_BACKEND=vuln-prioritizer-workbench-backend
DOCKER_IMAGE_FRONTEND=vuln-prioritizer-workbench-frontend
TAG=local

# Vuln Prioritizer provider and legacy Workbench settings.
NVD_API_KEY=
VULN_PRIORITIZER_NVD_API_KEY_ENV=NVD_API_KEY
VULN_PRIORITIZER_MAX_UPLOAD_MB=25
VULN_PRIORITIZER_CSRF_TOKEN=
VULN_PRIORITIZER_ALLOWED_HOSTS=127.0.0.1,localhost
